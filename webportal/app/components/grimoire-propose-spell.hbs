<div class="grimoire-propose-spell">
  <h4>Propose a New Spell</h4>
  <p class="text-muted">Submit your spell idea to staff for review. Staff will approve or reject your proposal via the Jobs system.</p>

  <form>
    <div class="form-group">
      <label for="branch-select">Magic Branch *</label>
      <select id="branch-select" class="form-control" value={{selectedBranch}} onchange={{action (mut selectedBranch) value="target.value"}}>
        <option value="">-- Select a branch --</option>
        {{#each branches as |branch|}}
          <option value={{branch.key}}>{{branch.name}}</option>
        {{/each}}
      </select>
    </div>

    <div class="form-group">
      <label for="spell-name">Spell Name *</label>
      <input type="text" id="spell-name" class="form-control" placeholder="e.g., Fireball" value={{spellName}} onchange={{action (mut spellName) value="target.value"}}>
    </div>

    <div class="form-row">
      <div class="form-group col-md-6">
        <label for="min-skill">Minimum Skill *</label>
        <input type="number" id="min-skill" class="form-control" min="0" placeholder="0" value={{minimumSkill}} onchange={{action (mut minimumSkill) value="target.value"}}>
      </div>
      <div class="form-group col-md-6">
        <label for="difficulty">Difficulty *</label>
        <input type="number" id="difficulty" class="form-control" min="0" placeholder="0" value={{difficulty}} onchange={{action (mut difficulty) value="target.value"}}>
      </div>
    </div>

    <div class="form-group">
      <label for="description">Description *</label>
      <textarea id="description" class="form-control" rows="4" placeholder="Describe what this spell does and how it works" value={{description}} onchange={{action (mut description) value="target.value"}}></textarea>
    </div>

    <div class="form-group">
      <button type="button" class="btn btn-primary" {{action "submitProposal"}} disabled={{isSubmitting}}>
        {{#if isSubmitting}}Submitting...{{else}}Submit Proposal{{/if}}
      </button>
      <button type="button" class="btn btn-secondary" {{action "cancel"}} disabled={{isSubmitting}}>
        Clear
      </button>
    </div>

    <p class="text-muted small">
      <strong>Note:</strong> All fields are required. Minimum skill and difficulty must be non-negative numbers.
    </p>
  </form>
</div>
